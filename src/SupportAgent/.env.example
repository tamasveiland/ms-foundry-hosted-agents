# Local development environment variables
# Copy this file to .env and fill in the values from your azd environment
# Run: azd env get-values > .env (then clean up the output)

# Azure AI Project Configuration
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project-name

# Azure OpenAI Configuration  
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
OPENAI_API_VERSION=2024-06-01
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# Application Insights (optional for local development)
# Leave blank or remove this line to disable App Insights locally
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# Local Development Settings
AGENT_ENVIRONMENT=local
